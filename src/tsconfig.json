{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node", // Depricated in 7.0
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "types": ["vite/client", "youtube"],
    "ignoreDeprecations": "6.0" // Solves deprication issue
  },
  "include": ["./**/*", "../global.d.ts"]
}
